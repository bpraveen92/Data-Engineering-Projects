# Core AWS configuration
AWS_REGION=ap-south-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=

# Use http://localhost:4566 for localstack; leave empty for real AWS
AWS_ENDPOINT_URL=http://localhost:4566
KINESIS_ENDPOINT_URL=http://localhost:4566
DYNAMODB_ENDPOINT_URL=http://localhost:4566
GLUE_ENDPOINT_URL=http://localhost:4566

# Stream + table names
TRIP_START_STREAM=trip-start-stream
TRIP_END_STREAM=trip-end-stream
TRIP_LIFECYCLE_TABLE=trip_lifecycle

# Lambda/Glue naming
START_LAMBDA_NAME=etl-project-3-trip-start
END_LAMBDA_NAME=etl-project-3-trip-end
GLUE_JOB_NAME=etl-project-3-trip-aggregation
GLUE_DATABASE=etl_project_3_analytics

# S3 / Athena
AGGREGATION_BUCKET=etl-project-3-analytics-local
AGGREGATION_PREFIX=aggregations/hourly_zone_metrics
ATHENA_OUTPUT=s3://etl-project-3-analytics-local/athena-results/

# Local output path when running glue script in local scan mode
LOCAL_OUTPUT_PATH=./output/aggregations
