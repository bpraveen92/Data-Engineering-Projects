# ETL-Project-2 Environment Variables
# DO NOT commit .env — copy this file to .env and fill in your values.
#
# Runtime settings (stream name, paths, window size, etc.) are passed as
# CLI arguments to spark-submit / kinesis_stream_producer.py, not read
# from this file. Only variables consumed via os.getenv() live here.

AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=ap-south-2

KINESIS_STREAM_NAME=music-streams
KINESIS_REGION=ap-south-2
KINESIS_STREAM_ARN=arn:aws:kinesis:ap-south-2:<account-id>:stream/music-streams

S3_BUCKET=your-s3-bucket-name
SONGS_DATA_PATH=s3://your-s3-bucket-name/Project-2/sample_data_initial_load/songs.csv
USERS_DATA_PATH=s3://your-s3-bucket-name/Project-2/sample_data_initial_load/users.csv
OUTPUT_PATH=s3://your-s3-bucket-name/Project-2/aggregations/
CHECKPOINT_PATH=s3://your-s3-bucket-name/Project-2/checkpoints/
STREAMS_DATA_PATH=sample_data_initial_load/streams.csv

EMR_APP_ID=your-emr-app-id
EMR_EXECUTION_ROLE_ARN=arn:aws:iam::<account-id>:role/etl-project-2-emr-execution

KINESIS_ENDPOINT=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

SPARK_SQL_SHUFFLE_PARTITIONS=4

PRODUCER_BATCH_SIZE=20
PRODUCER_INTERVAL_SECONDS=5
PRODUCER_MAX_RECORDS=

CONSUMER_WINDOW_DURATION_MINUTES=5
CONSUMER_WATERMARK_MINUTES=1

LOG_LEVEL=INFO
